<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketLocalShirts3</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #000;
            color: white;
        }

        .navbar {
            background-color: #121212 !important;
            border-bottom: 1px solid #333 !important;
        }

        .nav-link {
            color: #aaa !important;
            transition: 0.3s;
            font-weight: 500;
        }

            .nav-link:hover {
                color: #00d4ff !important;
            }

        .navbar-brand span {
            font-weight: 800;
            letter-spacing: 1px;
        }

     
        .admin-sidebar {
            background-color: #121212;
            border-right: 1px solid #222;
            min-height: 100vh;
            padding-top: 20px;
        }

        .admin-nav-link {
            color: #aaa !important;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            text-decoration: none;
            transition: 0.3s;
        }

            .admin-nav-link:hover {
                color: #00d4ff !important;
                background: rgba(0, 212, 255, 0.05);
            }
    </style>
</head>
<body class="bg-black text-white">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <div class="container-fluid px-md-5">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Cliente" asp-action="Inicio">
                    <img src="~/imagenes/logo.png.png" alt="Logo" height="45" class="me-2">
                    <span class="text-white">MarketLocal<span style="color: #00d4ff;">Shirts</span></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">
                    <ul class="navbar-nav mx-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link px-2" asp-controller="Cliente" asp-action="Inicio">
                                <i class="bi bi-house-door me-1"></i> Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-2" asp-controller="Cliente" asp-action="Catalogo">
                                <i class="bi bi-grid me-1"></i> Catálogo
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-2" asp-controller="Cliente" asp-action="MisPedidos">
                                <i class="bi bi-bag-check me-1"></i> Mis pedidos
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-2" asp-controller="Cuenta" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-2" asp-controller="Cliente" asp-action="Registro">
                                <i class="bi bi-person-plus me-1"></i> Crear Cuenta
                            </a>
                        </li>

                        <li class="nav-item ms-2">
                            <form asp-controller="Usuarios" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link text-danger p-0 border-0" style="text-decoration: none; font-weight: 500; white-space: nowrap;">
                                    <i class="bi bi-power me-1"></i> Cerrar Sesión
                                </button>
                            </form>
                        </li>
                    </ul>

                    <div class="nav-item dropdown ms-lg-3">
                        <a class="nav-link dropdown-toggle btn btn-outline-info text-white px-4 rounded-pill"
                           href="#" id="navbarAdmin" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                           style="border: 2px solid #00d4ff !important; color: white !important; white-space: nowrap;">
                            <i class="bi bi-gear-fill me-2"></i>Admin Panel
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark shadow-lg mt-2"
                            style="border: 1px solid #00d4ff;">
                            <li><a class="dropdown-item py-2" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people me-2"></i>Usuarios</a></li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li><a class="dropdown-item py-2" asp-controller="Productos" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Productos</a></li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li><a class="dropdown-item py-2" asp-controller="Marcas" asp-action="Index"><i class="bi bi-tags me-2"></i>Marcas</a></li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li><a class="dropdown-item py-2" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-cart-check me-2"></i>Consultar Pedidos</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>