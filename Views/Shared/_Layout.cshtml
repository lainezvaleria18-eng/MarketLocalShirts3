<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketLocalShirts3</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #000;
            color: white;
        }

        .navbar {
            background-color: #121212 !important;
            border-bottom: 1px solid #333 !important;
        }

      
        .nav-link-custom {
            color: #aaaaaa !important; 
            font-weight: 500 !important;
            transition: all 0.3s ease; 
            border: 1px solid transparent;
            border-radius: 5px;

                margin: 3px 5px;
                width: 100%;
        }

           
            .nav-link-custom:hover {
                color: #00d4ff !important; 
                background-color: rgba(0, 212, 255, 0.1); 
                border: 1px solid #00d4ff;
                transform: translateY(-1px); 
            }

        .navbar-brand span {
            font-weight: 800;
            letter-spacing: 1px;
        }

    </style>

</head>
<body class="bg-black text-white">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark py-3">
            <div class="container-fluid px-md-5">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Cliente" asp-action="Inicio">
                    <img src="~/imagenes/logo.png.png" alt="Logo" height="45" class="me-2">
                    <span class="text-white">MarketLocal<span style="color: #00d4ff;">Shirts</span></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">
                        <ul class="navbar-nav mx-auto align-items-lg-center align-items-start w-100">

                     
                        @if (User?.Identity != null && !User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Cliente" asp-action="Inicio">
                                    <i class="bi bi-house-door me-1"></i> Inicio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Cliente" asp-action="Catalogo">
                                    <i class="bi bi-grid me-1"></i> Catálogo
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Cliente" asp-action="MisPedidos">
                                    <i class="bi bi-bag-check me-1"></i> Mis pedidos
                                </a>
                            </li>
                        }

                     
                        @if (User?.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Usuarios" asp-action="Index">
                                    <i class="bi bi-people me-1"></i> Usuarios
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Productos" asp-action="Index">
                                    <i class="bi bi-box-seam me-1"></i> Productos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Marcas" asp-action="Index">
                                    <i class="bi bi-tags me-1"></i> Marcas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Pedidos" asp-action="Index">
                                    <i class="bi bi-cart-check me-1"></i> Pedidos
                                </a>
                            </li>
                        }

                      
                        @if (User?.Identity == null || !User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Cuenta" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Iniciar sesión
                                </a>
                            </li>
                            <li class="nav-item border-start border-secondary ms-2 ps-2">
                                <a class="nav-link nav-link-custom px-3" asp-controller="Cliente" asp-action="Registro">
                                    <i class="bi bi-person-plus me-1"></i> Crear Cuenta
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-4">
                                <button type="button" class="nav-link btn btn-link text-danger p-0 border-0"
                                        style="text-decoration: none;"
                                        data-bs-toggle="modal" data-bs-target="#logoutModal">
                                    <i class="bi bi-power me-1"></i> Cerrar Sesión
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

 
    <div class="modal fade" id="logoutModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border border-info">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-warning me-2"></i> Confirmar</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    ¿Estás seguro de que deseas cerrar tu sesión actual?
                </div>

                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form asp-controller="Cuenta" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-danger">Sí, cerrar sesión</button>
                    </form>

                </div>

            </div>
        </div>
    </div>

</body>
</html>