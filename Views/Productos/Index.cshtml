@model IEnumerable<MarketLocalShirts3.Models.Producto>

@if (ViewBag.ProductosSinStock != null && ViewBag.ProductosSinStock.Count > 0)
{
    <div class="alert alert-warning">
        Hay productos sin stock
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2 class="text-white m-0 flex-grow-1 text-center">
        Panel de administración de productos
    </h2>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-box-seam me-1"></i> Agregar producto
    </a>

</div>

<form asp-action="Index"
      method="get"
      class="d-flex justify-content-center mb-4">


        <input type="text"
               name="buscar"
               class="form-control me-2"
               placeholder="Buscar producto..."
               style="width: 400px;"
               value="@Context.Request.Query["buscar"]" />


        <select name="marcaId"
                class="form-select me-2"
                style="width: 250px;">

            <option value="">Marcas</option>

            @foreach (var m in ViewBag.Marcas)
            {
                <option value="@m.Id">
                    @m.Nombre
                </option>
            }

        </select>


        <button type="submit"
                class="btn btn-success">
            Buscar
        </button>

</form>

<div class="card bg-dark border-secondary shadow-lg mt-4" style="border-radius: 10px; overflow: hidden; margin-left: 15px; margin-right: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover m-0 align-middle">
                <thead class="table-light text-dark">
                    <tr>
                        <th class="ps-4">Imagen</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Marca</th>
                        <th class="text-center pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr style="border-bottom: 1px solid #2d2d2d;">
                            <td class="ps-4">
                                <img src="~/imagenes/@p.Imagen" width="80" class="img-thumbnail bg-dark border-secondary" />
                            </td>

                            <td class="text-light">@p.Nombre</td>
                            <td class="text-light">@p.Descripcion</td>
                            <td>$@p.Precio</td>
                            <td>@p.Stock</td>
                            <td>@p.Marca?.Nombre</td>

                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm">
                                        Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>