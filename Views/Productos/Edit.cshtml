@model MarketLocalShirts3.Models.Producto

<div style="display:flex; justify-content:center; align-items:start; padding-top:30px; background-color:black; min-height:100vh; overflow:hidden;">
    <div style="width:340px; border:1px solid #333; padding:15px; background:#000; box-sizing:border-box;">

        <div style="background:#1e90ff; color:black; text-align:center; padding:8px; font-weight:bold; margin-bottom:15px; font-size:15px;">
            Editar producto
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div style="margin-bottom:8px;">
                <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Nombre de la playera:</label>
                <input asp-for="Nombre" style="width:100%; height:25px; border-radius:0; border:none; background:white; padding:0 5px; font-size:12px;" />
            </div>

            <div style="margin-bottom:8px;">
                <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Descripción:</label>
                <textarea asp-for="Descripcion" rows="2" style="width:100%; border-radius:0; border:none; background:white; resize:none; padding:5px; font-size:12px;"></textarea>
            </div>

            <div style="display:flex; gap:10px; margin-bottom:8px;">
                <div style="flex:1;">
                    <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Precio:</label>
                    <input asp-for="Precio" style="width:100%; height:25px; border-radius:0; border:none; background:white; padding:0 5px; font-size:12px;" />
                </div>
                <div style="flex:1;">
                    <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Stock:</label>
                    <input asp-for="Stock" style="width:100%; height:25px; border-radius:0; border:none; background:white; padding:0 5px; font-size:12px;" />
                </div>
            </div>

            <div style="margin-bottom:8px;">
                <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Imagen:</label>
                <input asp-for="Imagen" style="width:100%; height:25px; border-radius:0; border:none; background:white; padding:0 5px; font-size:12px;" />
            </div>

            <div style="margin-bottom:18px;">
                <label style="color:white; font-size:13px; display:block; margin-bottom:2px;">Categoría / Marca:</label>
                <select asp-for="MarcaId" asp-items="ViewBag.MarcaId" style="width:100%; height:25px; border-radius:0; border:none; background:white; font-size:12px;"></select>
            </div>

            <div style="display:flex; justify-content:center; gap:10px;">
                <button type="submit" style="background:#1e90ff; color:black; border:none; width:80px; height:28px; font-weight:bold; cursor:pointer; font-size:12px;">Guardar</button>
                <a asp-action="Index" style="background:#1e90ff; color:black; border:none; width:80px; height:28px; font-weight:bold; text-decoration:none; text-align:center; display:flex; align-items:center; justify-content:center; font-size:12px;">Volver</a>
            </div>
        </form>

    </div>
</div>