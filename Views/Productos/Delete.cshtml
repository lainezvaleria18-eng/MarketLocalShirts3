@model MarketLocalShirts3.Models.Producto

<div class="d-flex justify-content-center mt-5">

    <div style="width: 420px; border: 1px solid white; padding: 20px;">

        <div class="bg-danger text-center p-2 mb-3">
            <strong>Eliminar producto</strong>
        </div>

        <div class="text-white text-center mb-3">
            ¿Estás seguro de eliminar este producto?
        </div>

        <div class="mb-3">  
            <label class="text-white">Nombre:</label>
            <input value="@Model.Nombre" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="text-white">Precio:</label>
            <input value="@Model.Precio" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="text-white">Stock:</label>
            <input value="@Model.Stock" class="form-control" readonly />
        </div>

        <div class="mb-4">
            <label class="text-white">Marca:</label>
            <input value="@Model.Marca?.Nombre" class="form-control" readonly />
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="text-center">
                <button type="submit" class="btn btn-danger me-2">
                    Eliminar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancelar
                </a>
            </div>
        </form>

    </div>

</div>