@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="d-flex justify-content-center align-items-center" style="height:70vh;">

    <div class="card bg-dark text-white p-4" style="width:350px;">

        <h3 class="text-center mb-4">Iniciar sesión</h3>

        <form asp-controller="Cuenta" asp-action="Login" method="post">

            <div class="mb-3">
                <input type="email" name="Email" class="form-control" placeholder="Email" required />
            </div>

            <div class="mb-3">
                <input type="password" name="Password" class="form-control" placeholder="Contraseña" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Ingresar
            </button>

        </form>

        <div class="text-center mt-3">
            <a asp-controller="Cuenta" asp-action="RecuperarPassword">
                ¿Olvidaste tu contraseña?
            </a>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 mt-3 text-center" style="font-size: 0.9rem;">
                <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
            </div>
        }

    </div>

</div>