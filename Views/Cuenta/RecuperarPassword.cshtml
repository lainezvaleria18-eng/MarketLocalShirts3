@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="d-flex justify-content-center align-items-center" style="height:70vh;">

    <div class="card bg-dark text-white p-4" style="width:400px;">

        <h3 class="text-center mb-4">Recuperar contraseña</h3>

        <form asp-controller="Cuenta" asp-action="GuardarPassword" method="post">

            <div class="mb-3">
                <input type="email" name="Email" class="form-control" placeholder="Email" required />
            </div>

            <div class="mb-3">
                <input type="password" name="NuevaPassword" class="form-control" placeholder="Nueva contraseña" required />
            </div>

            <div class="mb-3">
                <input type="password" name="ConfirmarPassword" class="form-control" placeholder="Confirmar contraseña" required />
            </div>

            <button type="submit" class="btn btn-success w-100">
                Guardar nueva contraseña
            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="text-danger text-center mt-2">
                @ViewBag.Error
            </div>
        }

    </div>

</div>