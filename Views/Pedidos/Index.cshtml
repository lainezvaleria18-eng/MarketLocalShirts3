@model IEnumerable<MarketLocalShirts3.Models.Pedido>

<h2 class="text-white">Consultar Pedidos</h2>

<table class="table table-dark table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var p in Model)
        {
            <tr>

                <td>
                    @p.Id
                </td>

                <td>
                    @p.Usuario?.Nombre
                </td>

                <td>
                    @p.FechaPedido.ToShortDateString()
                </td>

                <td>
                    @p.Estado
                </td>

                <td>
                    <a asp-action="Detalle"
                           asp-route-id="@p.Id"
                           class="btn btn-info btn-sm">
                        Ver Detalle
                    </a>
                </td>

            </tr>
        }

    </tbody>

</table>