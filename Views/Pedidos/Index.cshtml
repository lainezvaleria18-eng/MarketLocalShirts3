@model IEnumerable<MarketLocalShirts3.Models.Pedido>

<div id="headerPedidosAdmin" class="d-flex justify-content-between align-items-center mb-4">
    <h2 id="tituloPedidosAdmin" class="text-white m-0 flex-grow-1 text-center">Consultar Pedidos</h2>
</div>

<div class="mb-4">
    <form id="formPedidosAdmin" asp-action="Index" method="get" class="row g-2 align-items-center justify-content-center">
        <div class="col-md-5">
            <input type="text" name="buscar" class="form-control"
                   placeholder="Buscar cliente"
                   value="@Context.Request.Query["buscar"]" />
        </div>

        <div class="col-md-4">
            <input type="date" name="fecha" class="form-select"
                   value="@Context.Request.Query["fecha"]" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-success w-100 fw-bold">
                BUSCAR
            </button>
        </div>
    </form>
</div>

<div class="card bg-dark border-secondary shadow-lg mt-4">
    <div class="card-header border-secondary bg-transparent py-3">
        <h5 class="text-info m-0 fw-bold">Registros del Sistema</h5>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover m-0 align-middle">
                <thead class="table-light text-dark">
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>@p.Usuario?.Nombre</td>
                            <td>@p.FechaPedido.ToShortDateString()</td>
                            <td class="text-center">
                                @{
                                    var colorBadge = p.Estado switch
                                    {
                                        "Pendiente" => "bg-warning text-dark",
                                        "En Proceso" => "bg-info text-dark",
                                        "Enviado" => "bg-primary",
                                        "Entregado" => "bg-success",
                                        "Cancelado" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @colorBadge">@p.Estado</span>
                            </td>

                            <td class="text-center">
                                <a asp-controller="Cliente"
                                       asp-action="DetallePedido"
                                       asp-route-id="@p.Id"
                                       class="btn btn-info btn-sm">
                                    Ver Detalle
                                </a>

                                <button class="btn btn-warning btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal-@p.Id">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 🔽 MODALES FUERA DE LA TABLA -->
@foreach (var p in Model)
{
    <div class="modal fade" id="editModal-@p.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content bg-dark text-white">
                <form asp-action="ActualizarEstado" method="post">
                    <div class="modal-header">
                        <h5>Pedido #@p.Id</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="idPedido" value="@p.Id" />

                        <label>Cambiar estado</label>
                        <select name="nuevoEstado" class="form-select">
                            <option value="Pendiente">Pendiente</option>
                            <option value="En Proceso">En Proceso</option>
                            <option value="Enviado">Enviado</option>
                            <option value="Entregado">Entregado</option>
                            <option value="Cancelado">Cancelado</option>
                        </select>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        <button class="btn btn-success">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- 🔽 PAGINACIÓN -->
<div class="d-flex justify-content-center mt-4">

    @if (ViewBag.TotalPaginas > 1)
    {
        @if (ViewBag.PaginaActual > 1)
        {
            <a class="btn btn-primary me-2"
                   href="?pagina=@(ViewBag.PaginaActual - 1)&buscar=@Context.Request.Query["buscar"]&fecha=@Context.Request.Query["fecha"]">
                Anterior
            </a>
        }

        <span class="text-white mx-2">
            Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas
        </span>

        @if (ViewBag.PaginaActual < ViewBag.TotalPaginas)
        {
            <a class="btn btn-primary ms-2"
                   href="?pagina=@(ViewBag.PaginaActual + 1)&buscar=@Context.Request.Query["buscar"]&fecha=@Context.Request.Query["fecha"]">
                Siguiente
            </a>
        }
    }
</div>

<div class="text-center mt-3">
    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
    {
        <a class="btn @(i == ViewBag.PaginaActual ? "btn-success" : "btn-outline-light") m-1"
               href="?pagina=@i&buscar=@Context.Request.Query["buscar"]&fecha=@Context.Request.Query["fecha"]">
            @i
        </a>
    }
</div>