@model MarketLocalShirts3.Models.Usuario

@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4 shadow" style="width: 400px; background-color:#212529;">
        <h3 class="text-center text-white mb-4">Crear Cuenta</h3>

        <form asp-action="Registro" method="post">

            <div class="mb-3">
                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Nombre"
                       required />
            </div>

            <div class="mb-3">
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Email"
                       required />
            </div>

            <div class="mb-3">
                <input asp-for="PasswordHash"
                       type="password"
                       class="form-control"
                       placeholder="Contraseña"
                       required />
                       </div>
             <div>
                <div class="mb-3">
                    <input name="Direccion"
                           class="form-control"
                           placeholder="Dirección"
                           required />
                </div>

                <div class="mb-3">
                    <input name="Telefono"
                           class="form-control"
                           placeholder="Teléfono"
                           required />
                </div>

                <div class="mb-3">
                    <input name="Ciudad"
                           class="form-control"
                           placeholder="Ciudad"
                           required />
                </div>

            </div>

            <button type="submit" class="btn btn-primary w-100">
                Crear Cuenta
            </button>

        </form>
    </div>

</div>
