@model MarketLocalShirts3.Models.Usuario

@{
    ViewData["Title"] = "Crear Cuenta";
}


<div class="d-flex justify-content-center align-items-center px-3" style="min-height: 100vh;">


    <div class="card p-4 shadow" style="width: 100%; max-width: 400px; background-color:#212529; border-radius:12px;">


        <h3 class="text-center text-white mb-4">Crear Cuenta</h3>

        <form asp-action="Registro" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger small mb-2"></div>

            <div class="mb-3">
                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Nombre" />

                <span asp-validation-for="Nombre"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       placeholder="Correo electrónico" />

                <span asp-validation-for="Email"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="PasswordHash"
                       type="password"
                       class="form-control"
                       placeholder="Contraseña" />

                <span asp-validation-for="PasswordHash"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="ConfirmarPassword"
                       type="password"
                       class="form-control"
                       placeholder="Confirmar contraseña" />

                <span asp-validation-for="ConfirmarPassword"
                      class="text-danger small"></span>
            </div>


            <hr class="text-secondary" />

            <div class="mb-3">
                <input asp-for="Cliente.Direccion"
                       class="form-control"
                       placeholder="Dirección" />

                <span asp-validation-for="Cliente.Direccion"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Cliente.Telefono"
                       type="tel"
                       class="form-control"
                       placeholder="Teléfono" />

                <span asp-validation-for="Cliente.Telefono"
                      class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Cliente.Ciudad"
                       class="form-control"
                       placeholder="Ciudad" />

                <span asp-validation-for="Cliente.Ciudad"
                      class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">
                Crear Cuenta
            </button>

            <div class="text-center mt-3">
                <small class="text-light">
                    ¿Ya tienes cuenta?
                    <a asp-controller="Usuarios" asp-action="Login" class="text-primary text-decoration-none">
                        Inicia sesión
                    </a>
                </small>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}