@if (TempData["SinStock"] != null)
{
    <div class="alert alert-danger">
        @TempData["SinStock"]
    </div>
}

@model IEnumerable<MarketLocalShirts3.Models.Producto>

<h2 class="text-white mb-4">Catálogo De Playeras Para Hombres</h2>

<script>
//Buscar por nombre y marca
</script>

<form method="get" asp-action="Catalogo" class="mb-4">
    <div class="row g-2">

     
        <div class="col-md-8">
            <input type="text"
                   name="buscar"
                   class="form-control"
                   placeholder="Buscar producto por nombre..."
                   value="@ViewBag.Busqueda" />
        </div>

        <div class="col-md-3">
            <select name="marcaId" class="form-select">

                <option value="0">Todas las marcas</option>
                @foreach (var marca in ViewBag.Marcas)
                {
                    if (ViewBag.MarcaSeleccionada == marca.Id)
                    {
                        <option value="@marca.Id" selected>
                            @marca.Nombre
                        </option>
                    }
                    else
                    {
                        <option value="@marca.Id">
                            @marca.Nombre
                        </option>
                    }
                }
               }

            </select>
        </div>

     
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">
                Buscar
            </button>
        </div>

    </div>
</form>

<div class="row" id="listaProductos">

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No se encontraron productos
        </div>
    }

    @foreach (var p in Model)
    {
        <div class="col-md-3 mb-4 producto-item">
            <div class="card bg-dark text-white h-100" data-nombre="@p.Nombre.ToLower()">
                <img src="@Url.Content("~/imagenes/" + p.Imagen)" class="card-img-top" style="height:300px;object-fit:cover;" />
                <div class="card-body">
                    <p>Nombre: @p.Nombre</p>
                    <p>Marca: @p.Marca?.Nombre</p>
                    <p>Descripción: @p.Descripcion</p>
                    <p>Precio: $@p.Precio</p>
                </div>
                <div class="card-footer bg-dark border-0">
                    @if (p.Stock == 0)
                    {
                        <span class="badge bg-danger">Producto agotado</span>
                    }
                    else
                    {
                        <a asp-controller="Carrito"
                           asp-action="Agregar"
                           asp-route-id="@p.Id"
                           class="btn btn-primary">
                            Agregar al carrito
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>
  