@model IEnumerable<MarketLocalShirts3.Models.Pedido>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-white m-0 flex-grow-1 text-center fw-bold">
        Mis pedidos
    </h2>
</div>

<form method="get" class="row mb-4 justify-content-center align-items-center">

    <div class="col-md-3 mb-2">
        <input type="date"
               name="fecha"
               class="form-control shadow-sm"
               value="@Context.Request.Query["fecha"]" />
    </div>

    <div class="col-md-auto mb-2">

        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">
            Buscar
        </button>

    </div>

</form>


<div class="card bg-dark border-0 shadow-lg" style="border-radius: 15px; overflow: hidden;">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead class="table-light">
                
                <tr>
                    <th class="py-3 px-4 text-dark">ID</th>
                    <th class="py-3 text-dark">Fecha</th>
                    <th class="py-3 text-dark">Nombre</th>
                    <th class="py-3 text-dark">Estado</th>
                    <th class="py-3 px-4 text-dark text-center">Detalle</th>
                </tr>
            </thead>

            <tbody class="border-top-0">
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="py-3 px-4 fw-bold">@p.Id</td>
                        <td class="py-3 text-white-50">@p.FechaPedido.ToShortDateString()</td>
                        <td class="py-3">@p.Usuario?.Nombre</td>
                        <td class="py-3">
                            @* Un pequeño toque de color según el estado para que se vea más profesional *@
                            <span class="badge @(p.Estado == "Entregado" ? "bg-success" : "bg-warning text-dark")">
                                @p.Estado
                            </span>
                        </td>
                        <td class="py-3 px-4 text-center">
                            <a asp-action="DetallePedido"
                               asp-route-id="@p.Id"
                               class="btn btn-primary btn-sm px-3 shadow-sm fw-bold">
                                Ver detalle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>