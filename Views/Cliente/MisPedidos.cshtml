@model IEnumerable<MarketLocalShirts3.Models.Pedido>

<h2 class="text-white mb-4">Mis pedidos</h2>

<form method="get" class="row mb-3">

    <!-- Buscar por nombre -->
    <div class="col-md-4">
        <input type="text"
               name="buscar"
               class="form-control"
               placeholder="Buscar por nombre producto"
               value="@Context.Request.Query["buscar"]" />
    </div>

    <!-- Buscar por fecha -->
    <div class="col-md-3">
        <input type="date"
               name="fecha"
               class="form-control"
               value="@Context.Request.Query["fecha"]" />
    </div>

    <!-- Botón -->
    <div class="col-md-2">
        <button type="submit"
                class="btn btn-primary">
            Buscar
        </button>
    </div>

</form>

<table class="table table-dark">
    <thead>
        <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Detalle</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.FechaPedido.ToShortDateString()</td>
                <td>@p.Estado</td>
                <td>
                    <a asp-action="DetallePedido"
                       asp-route-id="@p.Id"
                       class="btn btn-primary">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>