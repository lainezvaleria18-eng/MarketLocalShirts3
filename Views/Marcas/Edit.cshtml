@model MarketLocalShirts3.Models.Marca

<h2 class="text-white">Editar Marca</h2>

<form asp-action="Edit">

    <input type="hidden"
           asp-for="Id" />

    <div class="form-group mb-3">
        <label class="text-white">
            Nombre
        </label>

        <input asp-for="Nombre"
               class="form-control" />

        <span asp-validation-for="Nombre"
              class="text-danger">
        </span>
    </div>

    <button type="submit"
            class="btn btn-warning">
        Guardar cambios
    </button>

    <a asp-action="Index"
           class="btn btn-secondary">
        Volver
    </a>

</form>