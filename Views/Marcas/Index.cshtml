@model IEnumerable<MarketLocalShirts3.Models.Marca>

<div class="d-flex justify-content-between align-items-center mb-4 px-3">
    <h2 class="text-white m-0 flex-grow-1 text-center">
        Mantenimiento de Marcas
    </h2>

    <div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-square-fill"></i> Agregar Marca
        </a>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-lg mt-4" style="border-radius: 10px; overflow: hidden; margin-left: 15px; margin-right: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover m-0 align-middle">
                <thead class="table-light text-dark">
                    <tr>
                        <th class="ps-4">Nombre</th>
                        <th class="text-center pe-4">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var m in Model)
                    {
                        <tr style="border-bottom: 1px solid #2d2d2d;">
                            <td class="ps-4 fw-bold">@m.Nombre</td>

                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit"
                                       asp-route-id="@m.Id"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@m.Id"
                                       class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>