@model MarketLocalShirts3.Models.Marca

<h2 class="text-white">Agregar Marca</h2>

<form asp-action="Create">

    <div class="form-group mb-3">
        <label class="text-white">
            Nombre de la marca
        </label>

        <input asp-for="Nombre"
               class="form-control" />

        <span asp-validation-for="Nombre"
              class="text-danger">
        </span>
    </div>

    <button type="submit"
            class="btn btn-success">
        Guardar
    </button>

    <a asp-action="Index"
           class="btn btn-secondary">
        Volver
    </a>

</form>