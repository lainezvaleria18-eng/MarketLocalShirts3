@model MarketLocalShirts3.Models.Marca

<div class="d-flex justify-content-center mt-5">

    <div style="width: 400px; border: 1px solid white; padding: 20px;">

        <!-- Título azul -->
        <div class="bg-primary text-center p-2 mb-3">
            <strong>Agregar marca</strong>
        </div>

        <form asp-action="Create">

            <div class="mb-3">
                <label class="text-white">Nombre de la marca:</label>

                <input asp-for="Nombre" class="form-control" />

                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- Botones -->
            <div class="text-center">
                <button type="submit" class="btn btn-primary me-2">
                    Guardar
                </button>

                <a asp-action="Index" class="btn btn-primary">
                    Volver
                </a>
            </div>

        </form>

    </div>

</div>