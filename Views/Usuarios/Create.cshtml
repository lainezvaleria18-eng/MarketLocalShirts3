@model MarketLocalShirts3.ViewModels.UsuarioViewModel

<style>
    body {
        background-color: #000;
        font-family: Arial, Helvetica, sans-serif;
    }

    .form-box {
        width: 380px;
        border: 1px solid #555;
        padding: 20px;
        color: #fff;
    }

    .form-title {
        background-color: #2196f3;
        color: #000;
        text-align: center;
        padding: 6px;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .form-row {
        display: flex;
        flex-direction: column;
        margin-bottom: 10px;
        font-size: 14px;
    }

        .form-row input,
        .form-row select {
            width: 100%;
            height: 22px;
            font-size: 13px;
            margin-top: 3px;
        }

    .form-buttons {
        text-align: center;
        margin-top: 15px;
    }

    .btn-simple {
        background-color: #2196f3;
        border: none;
        color: #000;
        padding: 4px 14px;
        font-size: 13px;
        margin: 0 5px;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-simple:hover {
            opacity: 0.9;
        }
</style>

<div style="display:flex; justify-content:center; align-items:center; height:80vh;">
    <div class="form-box">

        <div class="form-title">Formulario de usuario</div>

        <form asp-action="Create" method="post" >
            @Html.AntiForgeryToken()

            <div class="form-row">
                <label>Nombre:</label>
                <input asp-for="Nombre" />
                <span asp-validation-for="Nombre" style="color:red;"></span>
            </div>

            <div class="form-row">
                <label>Email:</label>
                <input asp-for="Email" type="text" />
                <span asp-validation-for="Email" style="color:red;"></span>
            </div>

            <div class="form-row">
                <label>Contraseña:</label>
                <input asp-for="PasswordHash" type="password" />
                <span asp-validation-for="PasswordHash" style="color:red;"></span>
            </div>

            <div class="form-row">
                <label>Dirección:</label>
                <input asp-for="Direccion" name="Direccion" />
            </div>

            <div class="form-row">
                <label>Teléfono:</label>
                <input asp-for="Telefono" name="Telefono" />
            </div>

            <div class="form-row">
                <label>Ciudad:</label>
                <input asp-for="Ciudad" name="Ciudad" />
            </div>

            <div class="form-row">
                <label>Rol:</label>
                <select asp-for="RolId" asp-items="ViewBag.RolId"></select>
                <span asp-validation-for="RolId" style="color:red;"></span>
            </div>

            <div class="form-buttons">
                <button type="submit" class="btn-simple">Guardar</button>
                <a asp-action="Index" class="btn-simple">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}