@model MarketLocalShirts3.Models.Usuario

<div class="d-flex justify-content-center">
    <div class="card bg-black text-white p-4" style="width:400px;">
        <h4 class="bg-primary text-center p-2">Formulario de usuario</h4>

        <form asp-action="Create">
            <label>Nombre:</label>
            <input asp-for="Nombre" class="form-control mb-2" />

            <label>Email:</label>
            <input asp-for="Email" class="form-control mb-2" />

            <label>Contraseña:</label>
            <input asp-for="PasswordHash" type="password" class="form-control mb-2" />

            <div class="form-group">
                <label>Dirección</label>
                <input name="direccion" class="form-control" />
            </div>

            <div class="form-group">
                <label>Teléfono</label>
                <input name="telefono" class="form-control" />
            </div>

                <label>Ciudad</label>
                <input name="ciudad" class="form-control" />
            </div>

            <label>Rol:</label>
            <select asp-for="RolId" asp-items="ViewBag.RolId" class="form-control mb-3"></select>

            <div class="text-center">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>