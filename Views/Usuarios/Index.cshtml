@model IEnumerable<MarketLocalShirts3.Models.Usuario>

<div id="headerUsuarios" class="d-flex justify-content-between align-items-center mb-4 px-3">
    <h2 class="text-white m-0 flex-grow-1 text-center">
        Panel de administración de usuarios
    </h2>

    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Agregar usuario
    </a>
</div>

<form asp-action="Index" method="get" class="d-flex justify-content-center mb-4">
    <input type="text"
           name="buscar"
           class="form-control w-50 me-2"
           placeholder="Buscar usuario..."
           value="@ViewBag.Buscar" />

    <button type="submit" class="btn btn-success">
        Buscar
    </button>
</form>

<div class="card bg-dark border-secondary shadow-lg mt-4" style="border-radius: 10px; overflow: hidden; margin-left: 15px; margin-right: 15px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover m-0 align-middle">
                <thead class="table-light text-dark">
                    <tr>
                        <th class="ps-4">Nombre</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Activo</th>
                        <th>Fecha Registro</th>
                        <th>Dirección</th>
                        <th>Teléfono</th>
                        <th>Ciudad</th>
                        <th class="text-center pe-4" style="width: 250px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr style="border-bottom: 1px solid #2d2d2d;">
                            <td class="font-size: 0.85rem;">@u.Nombre</td>
                            <td class="font-size: 0.85rem;">@u.Email</td>
                            <td>@u.Rol?.Nombre</td>
                            <td>
                                <span class="badge @(u.EsActivo ? "bg-success" : "bg-danger")">
                                    @(u.EsActivo ? "Sí" : "No")
                                </span>
                            </td>
                            <td style="font-size: 0.85rem;">@u.FechaRegistro</td>
                            <td class="font-size: 0.85rem;">@u.Cliente?.Direccion</td>
                            <td>@u.Cliente?.Telefono</td>
                            <td>@u.Cliente?.Ciudad</td>

                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Edit"
                                           asp-route-id="@u.Id"
                                           class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Bloquear"
                                           asp-route-id="@u.Id"
                                           class="btn btn-secondary btn-sm">
                                        Bloquear
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@u.Id"
                                           class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- PAGINACIÓN -->
<div class="d-flex justify-content-center mt-3">

    @if (ViewBag.PaginaActual > 1)
    {
        <a class="btn btn-primary me-2"
               href="?pagina=@(ViewBag.PaginaActual - 1)&buscar=@ViewBag.Buscar">
            Anterior
        </a>
    }

    <span class="text-white mt-2">
        Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas
    </span>

    @if (ViewBag.PaginaActual < ViewBag.TotalPaginas)
    {
        <a class="btn btn-primary ms-2"
               href="?pagina=@(ViewBag.PaginaActual + 1)&buscar=@ViewBag.Buscar">
            Siguiente
        </a>
    }

</div>

<!-- Números de página opcional -->
<div class="text-center mt-2">
    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
    {
        <a class="btn btn-outline-light m-1"
               href="?pagina=@i&buscar=@ViewBag.Buscar">
            @i
        </a>
    }
</div>