@model MarketLocalShirts3.Models.Usuario

<div style="display:flex; justify-content:center; align-items:start; padding-top:30px; background-color:black; min-height:100vh;">
    <div style="width:360px; border:1px solid #333; padding:20px; background:#000; box-sizing:border-box;">

        <div style="background:#dc3545; color:white; text-align:center; padding:10px; font-weight:bold; margin-bottom:20px; font-size:16px;">
            Eliminar usuario
        </div>

        <p style="color:white; text-align:center; font-size:14px; margin-bottom:20px;">¿Estás seguro de eliminar este usuario?</p>

        <div style="margin-bottom:20px;">
            <label style="color:gray; font-size:12px; display:block; margin-bottom:4px;">Nombre:</label>
            <div style="background:#fff; color:black; padding:5px 10px; font-size:13px; height:28px; display:flex; align-items:center;">@Model.Nombre</div>

            <label style="color:gray; font-size:12px; display:block; margin:10px 0 4px 0;">Email:</label>
            <div style="background:#fff; color:black; padding:5px 10px; font-size:13px; height:28px; display:flex; align-items:center;">@Model.Email</div>
        </div>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />
            <div style="display:flex; justify-content:center; gap:12px;">
                <button type="submit" style="background:#dc3545; color:white; border:none; width:90px; height:32px; font-weight:bold; cursor:pointer; font-size:13px;">Eliminar</button>
                <a asp-action="Index" style="background:#6c757d; color:white; border:none; width:90px; height:32px; font-weight:bold; text-decoration:none; text-align:center; display:flex; align-items:center; justify-content:center; font-size:13px;">Cancelar</a>
            </div>
        </form>
    </div>
</div>