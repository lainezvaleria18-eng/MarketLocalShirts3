@model List<MarketLocalShirts3.Models.CarritoItem>

@{
    var metodoPago = ViewBag.MetodoPago;
    decimal total = Model.Sum(x => x.Precio * x.Cantidad);
}

<div class="container-fluid py-5 px-4">
    <div class="card bg-dark border-0 shadow-lg rounded-4 overflow-hidden mb-4">
        <div class="card-header bg-black border-secondary p-4 text-center">
            <h1 class="text-white mb-1 fw-bold fs-3">
                <i class="bi bi-check2-circle text-success me-2"></i>Pedido Confirmado
            </h1>
            <p class="text-secondary mb-0">¡Gracias por tu compra, @ViewBag.Nombre!</p>
        </div>

        <div class="card-body p-4 border-bottom border-secondary">
            <h5 class="text-white text-uppercase small fw-bold text-secondary mb-3">Resumen de Envío</h5>
            <div class="row g-3 text-white">
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background: #1a1a1a;">
                        <small class="text-secondary d-block text-uppercase small">Cliente</small>
                        <span class="fw-bold">@ViewBag.Nombre</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background: #1a1a1a;">
                        <small class="text-secondary d-block text-uppercase small">Dirección</small>
                        <span class="fw-bold">@ViewBag.Direccion</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded-3" style="background: #1a1a1a;">
                        <small class="text-secondary d-block text-uppercase small">Teléfono</small>
                        <span class="fw-bold">@ViewBag.Telefono</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-dark border-0 shadow-lg rounded-4 overflow-hidden mb-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead class="bg-black text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Producto</th>
                        <th class="py-3">Marca</th>
                        <th class="py-3 text-center">Precio</th>
                        <th class="py-3 text-center">Cantidad</th>
                        <th class="py-3 text-end pe-4">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold">@item.Nombre</td>
                            <td class="text-secondary">@item.Marca</td>
                            <td class="text-center">$@item.Precio.ToString("0.00")</td>
                            <td class="text-center">
                                <span class="badge bg-secondary px-3 py-2">@item.Cantidad</span>
                            </td>
                            <td class="text-end pe-4 fw-bold text-info">$@((item.Precio * item.Cantidad).ToString("0.00"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row justify-content-end">
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-4 p-4" style="background: #1a1a1a;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-secondary fw-bold text-uppercase small">Método de pago:</span>
                    <span class="text-info fw-bold">@metodoPago</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4 border-top border-secondary pt-3">
                    <h4 class="text-white fw-bold mb-0">Total:</h4>
                    <h3 class="text-info fw-bold mb-0">$@total.ToString("0.00")</h3>
                </div>

                <form asp-action="FinalizarPedido" method="post" class="d-grid">
                    <button type="submit" class="btn btn-success fw-bold py-3 rounded-pill shadow-sm">
                        FINALIZAR PEDIDO
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #0d0d0d;
    }

    .table-hover tbody tr:hover {
        background-color: #222 !important;
    }
</style>