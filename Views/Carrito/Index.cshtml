@model List<MarketLocalShirts3.Models.CarritoItem>

<div class="container py-5">
    <h2 class="text-white mb-4 fw-bold">Tu Carrito</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 rounded-4" style="background: #1a1a1a;">
            <h4 class="text-white">Tu carrito está vacío</h4>
            <a asp-controller="Cliente" asp-action="Catalogo" class="btn btn-primary mt-3 rounded-pill px-4">Ir al catálogo</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card bg-dark border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle mb-0">
                            <thead class="bg-black text-secondary small text-uppercase">
                                <tr>
                                    <th class="ps-4 py-3">Producto</th>
                                    <th class="py-3">Marca</th>
                                    <th class="py-3 text-center">Precio</th>
                                    <th class="py-3 text-center">Cantidad</th>
                                    <th class="py-3 text-center">Subtotal</th>
                                    <th class="py-3 text-end pe-4">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-3 fw-bold">@item.Nombre</td>
                                        <td class="text-secondary">@item.Marca</td>
                                        <td class="text-center">$@item.Precio</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary px-3 py-2">@item.Cantidad</span>
                                        </td>
                                        <td class="text-center text-info fw-bold">$@(item.Precio* item.Cantidad)</td>
                                        <td class="text-end pe-4">
                                            <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-danger btn-sm rounded-pill px-3">
                                                Eliminar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-lg rounded-4 p-4" style="background: #1a1a1a;">
                    <h5 class="text-white mb-4 border-bottom border-secondary pb-2">Resumen de Pago</h5>

                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-secondary">Total a pagar:</span>
                        <h3 class="text-info fw-bold mb-0">$@Model.Sum(i => i.Precio * i.Cantidad)</h3>
                    </div>

                    <form asp-action="PedidoConfirmado" method="get">
                        <label class="text-white small mb-3 text-uppercase fw-bold text-secondary">Método de pago</label>

                        <div class="mb-4">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="metodoPago" id="efectivo" value="Efectivo" checked>
                                <label class="form-check-label text-white" for="efectivo">Efectivo</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="metodoPago" id="transferencia" value="Transferencia">
                                <label class="form-check-label text-white" for="transferencia">Transferencia</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold py-3 rounded-pill shadow-sm">
                                Confirmar pedido
                            </button>
                            <a asp-controller="Cliente" asp-action="Catalogo" class="btn btn-secondary py-2 rounded-pill">
                                Agregar más al carrito
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<style>
    body {
        background-color: #000;
    }

    .table-hover tbody tr:hover {
        background-color: #222 !important;
    }

    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>